texture UXMGSKIF, 32, 48 {xscale 4.0 yscale 4.0 patch UIXSCLIF, 0, 0}

// fonts are offsetted slightly different from any other type of graphic
// so this needs to be a composite graphic that's actually twice as big as the mugshot
// scaled down, and then offsetted by the specific amount compared to the mugshot
// so it all lines up and looks nice
// nothing is easy
texture UXMGSKIG, 64, 96
{
    xscale 8.0 yscale 8.0
    patch BLACKP, 0, 17
    patch BLACKP, 16, 17
    patch BLACKP, 32, 17
    patch BLACKP, 48, 17

    patch BLACKP, 0, 33
    patch BLACKP, 16, 33
    patch BLACKP, 32, 33
    patch BLACKP, 48, 33

    patch BLACKP, 0, 49
    patch BLACKP, 16, 49
    patch BLACKP, 32, 49
    patch BLACKP, 48, 49

    patch BLACKP, 0, 65
    patch BLACKP, 16, 65
    patch BLACKP, 32, 65
    patch BLACKP, 48, 65
}

