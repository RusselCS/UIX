texture UXMGSKIA, 32, 48 {xscale 4.0 yscale 4.0 patch UIXSCLIA, 0, 0}
texture UXMGSKIB, 32, 48 {xscale 4.0 yscale 4.0 patch UIXSCLIB, 0, 0}
texture UXMGSKIC, 32, 48 {xscale 4.0 yscale 4.0 patch UIXSCLIC, 0, 0}
texture UXMGSKID, 32, 48 {xscale 4.0 yscale 4.0 patch UIXSCLID, 0, 0}
