function int clamp(int x, int n, int m)
{
    if(x > m)
        return m;
    if(x < n)
        return n;
    return x;
}

function int centerRange(int range, int dividend, int divisor)
{
    return ((range/divisor) >> 1) + dividend*range/divisor - (range >> 1);
}

// Test functions =====================================================================================================

script "uixitem_giver" (void)
{
    until(timer()>=3)
        delay(1);

    for(int i = 0; i < UIX_INV_LMT; i++) {
        if(StrLen(getItemProperty(IT_ACTOR, i)) == 0)
            continue;
        GiveInventory(getItemProperty(IT_ACTOR, i), getItemProperty(IT_AMOUNT, i));
    }
}

